# Resend email delivery — https://resend.com
# The "from" domain (axiallabs.com) must be verified in Resend before sending.
# For local testing without domain verification, use onboarding@resend.dev in the route.
RESEND_API_KEY=re_...

# Upstash Redis — rate limiting on /api/contact (5 req / 60s per IP)
# Create a Redis database at https://upstash.com and copy the REST credentials.
# If not set, rate limiting is skipped (safe for local dev).
UPSTASH_REDIS_REST_URL=https://YOUR_DB.upstash.io
UPSTASH_REDIS_REST_TOKEN=YOUR_TOKEN

# Build metadata — injected by Vercel CI or set manually
NEXT_PUBLIC_VERSION=1.0.0
NEXT_PUBLIC_COMMIT_SHA=abc1234
